{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "WorkerSettings": {
    "SharedHost": 0, //是否為收集所有json檔的主機(0:否,1:是)(1會刪除SharedPath的資料)
    "TaskHost": 0, //是否監控排程(0:否,1:是)
    "UrlHost": 0, //是否監控URL(0:否,1:是)
    "ServeHost": 0, //是否監控服務(0:否,1:是)
    "UseRunInterval": 0, //執行間隔類型(0=依各自分鐘排程 1=統一照RunInterval)
    "RunInterval": 30000, //執行間隔(毫秒)
    "StorageDays": 60, //json保存天數
    "SharedJsonTotal": 10, //寫入共享資料夾Json數量(0:不限制)
    "LocalPath": "C:\\SystemMonitoringLogs", //本機資料夾路徑
    "SharedPath": "C:\\SystemMonitoringLogs\\Share", //共享資料夾路徑
    "TaskPath": "\\", //排程路徑
    "NotifyInterval": "5", //異常通知間隔(分鐘)(若不通知設定0)
    "RequestTimeout": "60", //網頁請求時間
    "HttpUrls": [

    ],
    "Serve": [

    ],
    "DiskEveryMinutes": 1,
    "UrlEveryMinutes": 1,
    "TaskEveryMinutes": 5,
    "ServeEveryMinutes": 5,
    "TransferMode": "Api", // Folder / Api / Both
    "UseCentralApi": 0, // 1=啟用API，0=不啟用
    "CentralApiBaseUrl": "",
    "CentralApiToken": "" // 有需要再放 token
  }
}
